<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/searchPoster"
        android:layout_width="160dp"
        android:layout_height="220dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">



        <ImageView
            android:id="@+id/imgView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            />

    </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/searchTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Movie Title"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/searchPoster"
                app:layout_constraintTop_toTopOf="@+id/searchPoster"/>

            <TextView
                android:id="@+id/searchCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                app:layout_constraintStart_toEndOf="@+id/searchPoster"
                app:layout_constraintTop_toBottomOf="@+id/searchTitle"
                />

            <TextView
                android:id="@+id/searchYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026"
                app:layout_constraintStart_toEndOf="@+id/searchPoster"
                app:layout_constraintTop_toBottomOf="@+id/searchCategory"/>
</androidx.constraintlayout.widget.ConstraintLayout>

