<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.am.moviesfix.ui.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />


    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.am.moviesfix.ui.DetailFragment"
        android:label="Detail" />

    <fragment
        android:id="@+id/favouriteFragment"
        android:name="com.am.moviesfix.ui.FavouriteFragment"
        android:label="fragment_favourite"
        tools:layout="@layout/fragment_favourite" />

    <action
        android:id="@+id/action_favourite_to_detail"
        app:destination="@id/detailFragment" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.am.moviesfix.ui.SearchFragment"
        android:label="Search"/>

    <action
        android:id="@+id/action_search_to_detail"
        app:destination="@+id/detailFragment"/>

</navigation>

